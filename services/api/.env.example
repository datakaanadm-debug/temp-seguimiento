APP_NAME=Interna
APP_ENV=local
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=true
APP_URL=http://api.interna.test:8000
APP_TIMEZONE=UTC
APP_LOCALE=es_MX
APP_ROOT_DOMAIN=interna.test
FRONTEND_URL=http://interna.test:3000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=interna
DB_USERNAME=interna_app
DB_PASSWORD=secret

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

# Cache / Queue / Session
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_DOMAIN=.interna.test
SESSION_LIFETIME=120

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:3000,*.interna.test,interna.test
SANCTUM_TOKEN_PREFIX=int_live_

# Reverb
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=interna-local
REVERB_APP_KEY=local
REVERB_APP_SECRET=local
REVERB_HOST=reverb.interna.test
REVERB_PORT=8080
REVERB_SCHEME=http

# Mail (Resend)
MAIL_MAILER=resend
RESEND_API_KEY=

# Storage (Cloudflare R2)
FILESYSTEM_DISK=r2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=interna-local
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true

# AI
ANTHROPIC_API_KEY=
AI_EMBEDDING_DIMENSIONS=1536

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Observability
SENTRY_LARAVEL_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Demo
DEMO_PASSWORD=password1234secure
